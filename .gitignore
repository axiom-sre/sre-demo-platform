# =============================================================================
# .gitignore — SRE Demo Platform
# =============================================================================

# ── Runtime state ─────────────────────────────────────────────────────────────
.pf-pids                    # port-forward PID tracking file (generated by start.sh)
*.pf-pids
/tmp/pf-*.log               # port-forward logs

# ── Secrets — NEVER commit these ──────────────────────────────────────────────
*.secret
*.secrets
*.env
.env
.env.*
!.env.example
secrets/
secret/
kubeconfig
kubeconfig.*
*.kubeconfig
grafana-admin-password
*-creds.yaml
*-credentials.yaml
serviceaccount-token*

# ── k6 output ─────────────────────────────────────────────────────────────────
k6-results/
*.k6.json
k6-summary*.json
k6-summary*.html

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
*.sublime-workspace
*.code-workspace

# ── Helm ──────────────────────────────────────────────────────────────────────
charts/*.tgz
*.tgz
Chart.lock

# ── Terraform (future) ────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ── Python (future tooling) ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/

# ── Node / npm (future tooling) ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
!scripts/*.log.example

# ── Backup files ──────────────────────────────────────────────────────────────
*.bak
*.orig
*.backup
*.old
